# Секреты для docker-compose (сервис web). Скопируйте в .env (не коммитится)
# и заполните реальными значениями — иначе PlantNetClient молча уйдёт в мок
# (см. server/API/Services/PlantNet/PlantNetClient.cs), а JWT/push не заработают.
#
# Для локального запуска без Docker (dotnet run/watch) секреты задаются через
# user-secrets — см. README.md.

PLANTNET_API_KEY=
JWT_SECRET=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
